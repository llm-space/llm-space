    "@codemirror/language": "6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.5",
    "@dayflow/blossom-color-picker-react": "^1.2.1",
    "@earendil-works/pi-ai": "catalog:",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@formkit/auto-animate": "^0.9.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@llm-space/core": "workspace:*",
    "@llm-space/ui": "workspace:*",
    "@lobehub/icons": "^5.10.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@sinm/react-chrome-tabs": "^2.6.3",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/codemirror-theme-basic": "^4.25.10",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/codemirror-theme-monokai": "^4.25.10",
    "@uiw/codemirror-theme-xcode": "^4.25.10",

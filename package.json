{
  "name": "llm-space",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check": "eslint .",
    "dev": "cd apps/desktop && bun run dev:hmr",
    "dev:cef": "cd apps/desktop && bun run dev:cef",
    "build:canary": "cd apps/desktop && bun run build:canary",
    "lint": "eslint --fix",
    "lint:check": "eslint .",
    "prepare": "husky"
  },
  "catalog": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-agent-core": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typebox": "^1.2.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "packageManager": "bun",
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typebox": "catalog:"
  }
}

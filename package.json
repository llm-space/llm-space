{
  "name": "llm-space",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check": "eslint .",
    "dev": "cd apps/desktop && bun run dev:hmr",
    "dev:cef": "cd apps/desktop && bun run dev:cef",
    "build:canary": "cd apps/desktop && bun run build:canary",
    "build:stable": "cd apps/desktop && bun run build:stable",
    "release": "bun scripts/release.ts",
    "release:canary": "bun scripts/release.ts --prerelease canary",
    "lint": "eslint --fix",
    "lint:check": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}": "eslint --fix"
  },
  "catalog": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-agent-core": "^0.80.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typebox": "^1.2.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typebox": "catalog:"
  }
}

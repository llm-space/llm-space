diff --git a/dist/api/bun/proc/native.ts b/dist/api/bun/proc/native.ts
--- a/dist/api/bun/proc/native.ts
+++ b/dist/api/bun/proc/native.ts
@@ -81,0 +82,52 @@ function getWindowPtr(winId: number) {
+const windowsWindowIconApi =
+	process.platform === "win32"
+		? dlopen("user32.dll", {
+				LoadImageW: {
+					args: [
+						FFIType.ptr,
+						FFIType.ptr,
+						FFIType.u32,
+						FFIType.i32,
+						FFIType.i32,
+						FFIType.u32,
+					],
+					returns: FFIType.ptr,

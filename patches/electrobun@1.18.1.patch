+				SendMessageW: {
+					args: [FFIType.ptr, FFIType.u32, FFIType.u64, FFIType.ptr],
+					returns: FFIType.ptr,
+				},
+			})
+		: null;
+
+function setWindowsWindowIcon(windowPtr: Pointer): void {
+	if (!windowsWindowIconApi) return;
+
+	const iconPath = Buffer.from(
+		`${join(process.cwd(), "..", "Resources", "app.ico")}\0`,
+		"utf16le",
+	);
+	const smallIcon = windowsWindowIconApi.symbols.LoadImageW(
+		null,
+		ptr(iconPath),
+		1,
+		16,
+		16,
+		0x10,
+	);
+	const largeIcon = windowsWindowIconApi.symbols.LoadImageW(
+		null,
+		ptr(iconPath),
+		1,
+		32,
+		32,
+		0x10,
+	);
+	if (smallIcon) {
+		windowsWindowIconApi.symbols.SendMessageW(windowPtr, 0x80, 0, smallIcon);
+	}
+	if (largeIcon) {
+		windowsWindowIconApi.symbols.SendMessageW(windowPtr, 0x80, 1, largeIcon);
+	}
+}

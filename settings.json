  "git.autoStash": true,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "file:/**/*.xlsx": "jupyter-data-wrangler"
  },
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "security.workspace.trust.untrustedFiles": "newWindow",
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "solidity": true
  },
  "workbench.colorTheme": "GitHub Dark",
  "editor.unicodeHighlight.allowedLocales": {
    "zh-hans": true
  },
  "editor.formatOnSave": true,
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "files.associations": {
    "*.html": "html",
    ".env": "shellscript",
    "*.json": "jsonc"
  },
  "editor.guides.indentation": false,
  "redhat.telemetry.enabled": false,
  "xml.server.binary.trustedHashes": [
    "9bbc60656c30aa348e24b82c127813991b3573fb55c417bd10944c52147197ba"
  ],
  "npm.keybindingsChangedWarningShown": true,
  "javascript.preferences.jsxAttributeCompletionStyle": "none",
  "typescript.preferences.jsxAttributeCompletionStyle": "none",
  "editor.linkedEditing": true,
  "blueprint.templatesPath": [
    "./.blueprint-templates",
    "~/workspaces/magiccube/blueprint-templates/src"
  ],
  "editor.minimap.enabled": false,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1"
  },
  "markdown-preview-github-styles.colorTheme": "light",
  "markdown-preview-github-styles.darkTheme": "light",
  "notebook.lineNumbers": "on",
  "go.toolsManagement.autoUpdate": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.startupEditor": "none",
  "http.proxy": "http://127.0.0.1:7890",
  "python.terminal.activateEnvironment": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "editor.stickyScroll.enabled": false,
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[ipynb]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "isort.args": ["--profile", "black"],
  "notebook.formatOnSave.enabled": true,
  "notebook.formatOnCellExecution": true,
  "python.createEnvironment.trigger": "off",
  "editor.stickyScroll.scrollWithEditor": false,
  "workbench.tree.enableStickyScroll": false,
  "flake8.args": ["--max-line-length=160"],
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask"
  ],
  "cmake.showOptionsMovedNotification": false,
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 2 }",
  "C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
  "C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
  "C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "sameLine",
  "C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
  "C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "sameLine",
  "C_Cpp.vcFormat.newLine.beforeElse": false,
  "C_Cpp.vcFormat.newLine.beforeCatch": false,
  "marscode.internal.enableCodelens": {
    "enableInlineDocumentation": false,
    "enableInlineUnitTest": false,
    "enableInlineExplain": false
  },
  "terminal.integrated.stickyScroll.enabled": false,
  "explorer.confirmPasteNative": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "cursor.cpp.disabledLanguages": ["scminput"],
  "cursor.general.disableHttp2": true
}
